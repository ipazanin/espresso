# Template for secrets.auto.tfvars (which is gitignored). Copy this file to
# secrets.auto.tfvars and fill in real values. terraform auto-loads any file
# matching *.auto.tfvars, so no -var-file flag is needed.
#
# Real production values can be read from GCP today via:
#   gcloud compute instance-templates describe espresso-web-api-vm-instance-template
#   gcloud compute instance-templates describe espresso-dashboard-instance-template

api_key_android     = "REPLACE_ME"
api_key_ios         = "REPLACE_ME"
api_key_web         = "REPLACE_ME"
api_key_parser      = "REPLACE_ME"
api_key_dev_ios     = "REPLACE_ME"
api_key_dev_android = "REPLACE_ME"

espresso_db_connection_string          = "User ID=postgres;Password=REPLACE_ME;Host=REPLACE_ME;Port=5432;Database=EspressoDb"
espresso_identity_db_connection_string = "User ID=postgres;Password=REPLACE_ME;Host=REPLACE_ME;Port=5432;Database=EspressoIdentity"

slack_analytics_webhook           = "https://hooks.slack.com/services/REPLACE_ME"
slack_crash_report_webhook        = "https://hooks.slack.com/services/REPLACE_ME"
slack_news_source_request_webhook = "https://hooks.slack.com/services/REPLACE_ME"

sendgrid_api_key    = "SG.REPLACE_ME"
admin_user_password = "REPLACE_ME"
